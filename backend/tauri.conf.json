{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "picsalot",
  "identifier": "com.cyan.picsalot",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "category": "Photography",
    "copyright": "Copyright © 2026 Cyan Froste",
    "shortDescription": "A simple batch image editor",
    "targets": [
      "nsis",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../assets/models/": "models/"
    }
  },
  "app": {
    "windows": [
      {
        "title": "picsalot",
        "label": "main",
        "decorations": false,
        "width": 1600,
        "height": 900,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": [
        "style-src"
      ],
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src * data: asset:; media-src * data: asset: http://asset.localhost;",
      "devCsp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src * data: asset:; media-src * data: asset: http://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  }
}